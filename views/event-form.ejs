<!DOCTYPE html>
<html>
<head>
  <title><%= event ? 'Edit' : 'Add' %> Event - Alumni Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/sidebar', { page: 'events' }) %>
<div class="main">
  <div class="topbar">
    <h1><%= event ? '✏️ Edit Event' : '➕ Add Event' %></h1>
    <div class="user-info"><div class="avatar">A</div><span><%= loggedUser %></span></div>
  </div>
  <div class="content">
    <% if (error) { %><div class="alert alert-danger">❌ <%= error %></div><% } %>
    <div class="form-card">
      <form method="POST" action="<%= event ? '/events/update/' + event._id : '/events' %>">
        <div class="form-grid">
          <div class="form-group full">
            <label>Event Title *</label>
            <input type="text" name="title" value="<%= event ? event.title : '' %>" placeholder="Enter event title" required/>
          </div>
          <div class="form-group">
            <label>Event Date *</label>
            <input type="date" name="eventDate" value="<%= event ? event.eventDate : '' %>" required/>
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" value="<%= event ? event.location : '' %>" placeholder="Event venue"/>
          </div>
          <div class="form-group full">
            <label>Description</label>
            <textarea name="description" rows="4" placeholder="Event description..."><%= event ? event.description : '' %></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">💾 <%= event ? 'Update' : 'Save' %> Event</button>
          <a href="/events" class="btn btn-warning">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
</body>
</html>
