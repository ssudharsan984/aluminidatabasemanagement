<!DOCTYPE html>
<html>
<head>
  <title><%= alumni ? 'Edit' : 'Add' %> Alumni - Alumni Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/sidebar', { page: 'alumni' }) %>
<div class="main">
  <div class="topbar">
    <h1><%= alumni ? '✏️ Edit Alumni' : '➕ Add Alumni' %></h1>
    <div class="user-info"><div class="avatar">A</div><span><%= loggedUser %></span></div>
  </div>
  <div class="content">
    <% if (error) { %><div class="alert alert-danger">❌ <%= error %></div><% } %>
    <div class="form-card">
      <form method="POST" action="<%= alumni ? '/alumni/update/' + alumni._id : '/alumni' %>">
        <div class="form-grid">
          <div class="form-group">
            <label>Full Name *</label>
            <input type="text" name="name" value="<%= alumni ? alumni.name : '' %>" placeholder="Enter full name" required/>
          </div>
          <div class="form-group">
            <label>Email *</label>
            <input type="email" name="email" value="<%= alumni ? alumni.email : '' %>" placeholder="Enter email" required/>
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" value="<%= alumni ? alumni.phone : '' %>" placeholder="Enter phone number"/>
          </div>
          <div class="form-group">
            <label>Batch Year *</label>
            <input type="number" name="batchYear" value="<%= alumni ? alumni.batchYear : '' %>" placeholder="e.g. 2020" required/>
          </div>
          <div class="form-group">
            <label>Department *</label>
            <select name="department" required>
              <option value="">-- Select Department --</option>
              <% ['Computer Science','Information Technology','Electronics','Mechanical','Civil','Electrical','MBA','MCA'].forEach(d => { %>
                <option value="<%= d %>" <%= alumni && alumni.department === d ? 'selected' : '' %>><%= d %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Company</label>
            <input type="text" name="company" value="<%= alumni ? alumni.company : '' %>" placeholder="Current company"/>
          </div>
          <div class="form-group">
            <label>Designation</label>
            <input type="text" name="designation" value="<%= alumni ? alumni.designation : '' %>" placeholder="Job title"/>
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" value="<%= alumni ? alumni.location : '' %>" placeholder="City, Country"/>
          </div>
          <div class="form-group full">
            <label>LinkedIn Profile</label>
            <input type="text" name="linkedin" value="<%= alumni ? alumni.linkedin : '' %>" placeholder="https://linkedin.com/in/username"/>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">💾 <%= alumni ? 'Update' : 'Save' %> Alumni</button>
          <a href="/alumni" class="btn btn-warning">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
</body>
</html>
